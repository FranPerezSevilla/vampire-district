{
  "name": "vampire-district",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "node --test tests/*.test.js",
    "test:input": "node --test tests/input-actions.test.js tests/geometry.test.js tests/input-system.test.js",
    "test:browser": "playwright test",
    "test:rc": "npm run test:unit && npm run test:browser",
    "serve:test": "python3 -m http.server 4173 --bind 127.0.0.1"
  },
  "dependencies": {
    "phaser": "3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
